{
    "name": "cypress_project",
    "version": "2.0.0",
    "description": "Web automation project with Cypress",
    "main": "index.js",
    "scripts": {
        "format": "prettier --write .",
        "pretest": "eslint .",
        "lint:fix": "eslint . --fix",
        "test:ui-headed-dev": "cypress run --headed --env version=dev",
        "test:ui-dev": "cypress run --env version=dev",
        "test:api-headed": "cypress open --env type=api",
        "test:api": "cypress run --env type=api",
        "test:report": "npx allure generate ./allure-results --clean",
        "report:open": "npx allure open allure-report",
        "docker:build": "docker build -t cypress-automation .",
        "docker:test": "docker compose run --rm tests",
        "docker:report": "docker compose run --rm report",
        "docker:serve": "docker compose up serve",
        "docker:execution": "npm run docker:test && npm run docker:report && npm run docker:serve"
    },
    "keywords": [
        "cypress",
        "javascript",
        "automation"
    ],
    "author": "Jonathan Fernández",
    "license": "ISC",
    "devDependencies": {
        "@eslint/js": "^9.38.0",
        "@faker-js/faker": "^9.8.0",
        "allure-commandline": "^2.38.1",
        "allure-cypress": "^3.6.0",
        "allure-js-commons": "^3.6.0",
        "cypress": "^15.9.0",
        "cypress-plugin-api": "^2.11.2",
        "cypress-plugin-steps": "^1.2.1",
        "eslint": "^9.38.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-cypress": "^5.2.0",
        "eslint-plugin-prettier": "^5.5.5",
        "prettier": "^3.8.1"
    },
    "dependencies": {
        "dotenv": "^16.5.0"
    }
}
